// CRM Pro - Esquema multi-tenant completo
// Toda tabla tenant-scoped lleva organizationId para aislamiento

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY: Organizaciones y usuarios
// ============================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  industry    String?
  website     String?
  phone       String?
  address     String?
  currency    String   @default("USD")
  timezone    String   @default("America/Mexico_City")
  locale      String   @default("es")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users         User[]
  contacts      Contact[]
  companies     Company[]
  leads         Lead[]
  pipelines     Pipeline[]
  deals         Deal[]
  activities    Activity[]
  tasks         Task[]
  products      Product[]
  quotes        Quote[]
  invoices      Invoice[]
  campaigns     Campaign[]
  emailLists    EmailList[]
  tickets       Ticket[]
  articles      Article[]
  tags          Tag[]
  notes         Note[]

  // BrandHub: agencia multi-marca
  brands             Brand[]
  brandProducts      BrandProduct[]
  endCustomers       EndCustomer[]
  sales              Sale[]
  commissions        Commission[]
  commissionRules    CommissionRule[]
  customFields       CustomField[]
  contractTemplates  ContractTemplate[]
  repAssignments     RepBrandAssignment[]
  attachments        Attachment[]

  @@index([slug])
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  AGENT
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  avatar         String?
  phone          String?
  role           Role     @default(AGENT)
  active         Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedContacts Contact[]  @relation("ContactOwner")
  assignedLeads    Lead[]     @relation("LeadOwner")
  assignedDeals    Deal[]     @relation("DealOwner")
  assignedTasks    Task[]     @relation("TaskAssignee")
  createdTasks     Task[]     @relation("TaskCreator")
  activities       Activity[]
  notes            Note[]
  ticketsAssigned  Ticket[]   @relation("TicketAgent")
  articlesCreated  Article[]
  campaignsCreated Campaign[]
  sessions         Session[]
  accounts         Account[]

  // BrandHub
  brandAssignments RepBrandAssignment[]
  salesAsRep       Sale[]               @relation("SaleRepresentative")
  commissions      Commission[]

  @@index([organizationId])
  @@index([email])
}

// NextAuth tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// CRM CORE: Contactos, Empresas, Leads
// ============================================

model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  website     String?
  phone       String?
  email       String?
  address     String?
  city        String?
  country     String?
  size        String?
  annualRevenue Decimal? @db.Decimal(15, 2)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contacts Contact[]
  deals    Deal[]

  @@index([organizationId])
  @@index([name])
}

model Contact {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  mobile      String?
  jobTitle    String?
  department  String?
  address     String?
  city        String?
  country     String?
  birthday    DateTime?
  source      String?
  avatar      String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId   String?
  owner     User?    @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  deals       Deal[]
  activities  Activity[]
  tasks       Task[]
  emailListMembers EmailListMember[]
  tickets     Ticket[]
  noteLinks   NoteList[]
  tags        ContactTag[]

  @@index([organizationId])
  @@index([email])
  @@index([companyId])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
}

model Lead {
  id          String     @id @default(cuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  company     String?
  jobTitle    String?
  source      String?
  status      LeadStatus @default(NEW)
  score       Int        @default(0)
  estimatedValue Decimal? @db.Decimal(15, 2)
  notes       String?    @db.Text
  convertedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ownerId String?
  owner   User?   @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  activities Activity[]
  tasks      Task[]

  @@index([organizationId])
  @@index([status])
  @@index([ownerId])
}

// ============================================
// PIPELINE: Etapas y Deals
// ============================================

model Pipeline {
  id          String  @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stages Stage[]
  deals  Deal[]

  @@index([organizationId])
}

model Stage {
  id          String @id @default(cuid())
  name        String
  order       Int
  probability Int    @default(0)
  color       String @default("#3b82f6")

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  deals Deal[]

  @@index([pipelineId])
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id            String     @id @default(cuid())
  title         String
  description   String?    @db.Text
  amount        Decimal    @db.Decimal(15, 2)
  currency      String     @default("USD")
  probability   Int        @default(0)
  status        DealStatus @default(OPEN)
  expectedCloseDate DateTime?
  closedAt      DateTime?
  lostReason    String?
  source        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id])

  stageId String
  stage   Stage  @relation(fields: [stageId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  activities Activity[]
  tasks      Task[]
  quotes     Quote[]

  @@index([organizationId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([status])
}

// ============================================
// TAREAS Y ACTIVIDADES
// ============================================

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  STATUS_CHANGE
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?      @db.Text
  occurredAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([contactId])
  @@index([dealId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId String
  creator   User   @relation("TaskCreator", fields: [creatorId], references: [id])

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assigneeId])
  @@index([status])
}

// ============================================
// VENTAS: Productos, Cotizaciones, Facturas
// ============================================

model Product {
  id          String   @id @default(cuid())
  sku         String
  name        String
  description String?  @db.Text
  category    String?
  price       Decimal  @db.Decimal(15, 2)
  cost        Decimal? @db.Decimal(15, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  unit        String   @default("unit")
  stock       Int?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  quoteLines   QuoteLine[]
  invoiceLines InvoiceLine[]

  @@unique([organizationId, sku])
  @@index([organizationId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id           String      @id @default(cuid())
  number       String
  status       QuoteStatus @default(DRAFT)
  issueDate    DateTime    @default(now())
  validUntil   DateTime?
  customerName String
  customerEmail String?
  customerAddress String?
  notes        String?     @db.Text
  terms        String?     @db.Text
  subtotal     Decimal     @db.Decimal(15, 2)
  taxAmount    Decimal     @db.Decimal(15, 2)
  discount     Decimal     @default(0) @db.Decimal(15, 2)
  total        Decimal     @db.Decimal(15, 2)
  currency     String      @default("USD")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  dealId String?
  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)

  lines    QuoteLine[]
  invoices Invoice[]

  @@unique([organizationId, number])
  @@index([organizationId])
}

model QuoteLine {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(15, 2)
  order       Int     @default(0)

  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

model Invoice {
  id           String        @id @default(cuid())
  number       String
  status       InvoiceStatus @default(DRAFT)
  issueDate    DateTime      @default(now())
  dueDate      DateTime
  paidDate     DateTime?
  customerName String
  customerEmail String?
  customerAddress String?
  customerTaxId String?
  notes        String?       @db.Text
  terms        String?       @db.Text
  subtotal     Decimal       @db.Decimal(15, 2)
  taxAmount    Decimal       @db.Decimal(15, 2)
  discount     Decimal       @default(0) @db.Decimal(15, 2)
  total        Decimal       @db.Decimal(15, 2)
  amountPaid   Decimal       @default(0) @db.Decimal(15, 2)
  currency     String        @default("USD")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  lines    InvoiceLine[]
  payments Payment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(15, 2)
  order       Int     @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
}

model Payment {
  id        String   @id @default(cuid())
  amount    Decimal  @db.Decimal(15, 2)
  method    String
  reference String?
  paidAt    DateTime @default(now())
  notes     String?

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ============================================
// MARKETING: Listas y Campañas
// ============================================

model EmailList {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  members   EmailListMember[]
  campaigns CampaignList[]

  @@index([organizationId])
}

model EmailListMember {
  id            String   @id @default(cuid())
  subscribedAt  DateTime @default(now())
  unsubscribed  Boolean  @default(false)

  listId    String
  list      EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  subject     String
  fromName    String
  fromEmail   String
  htmlContent String         @db.Text
  textContent String?        @db.Text
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  recipientsCount Int        @default(0)
  openedCount Int            @default(0)
  clickedCount Int           @default(0)
  createdAt   DateTime       @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  lists    CampaignList[]
  tracking EmailTracking[]

  @@index([organizationId])
}

model CampaignList {
  campaignId String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  listId String
  list   EmailList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@id([campaignId, listId])
}

model EmailTracking {
  id         String    @id @default(cuid())
  email      String
  sentAt     DateTime  @default(now())
  openedAt   DateTime?
  clickedAt  DateTime?

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
}

// ============================================
// SOPORTE: Tickets y Base de conocimiento
// ============================================

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id          String         @id @default(cuid())
  number      Int
  subject     String
  description String         @db.Text
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String?
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  agentId String?
  agent   User?   @relation("TicketAgent", fields: [agentId], references: [id], onDelete: SetNull)

  comments TicketComment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
}

model TicketComment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  internal  Boolean  @default(false)
  authorName String
  createdAt DateTime @default(now())

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model Article {
  id          String   @id @default(cuid())
  title       String
  slug        String
  content     String   @db.Text
  excerpt     String?
  category    String?
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@unique([organizationId, slug])
  @@index([organizationId])
}

// ============================================
// AUXILIARES: Tags, Notas
// ============================================

model Tag {
  id    String @id @default(cuid())
  name  String
  color String @default("#6366f1")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  contacts ContactTag[]

  @@unique([organizationId, name])
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model Note {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  contacts NoteList[]

  @@index([organizationId])
}

model NoteList {
  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([noteId, contactId])
}

// ============================================
// BRANDHUB: Agencia multi-marca
// Una Organization (agencia) representa varias Brand (empresas representadas).
// Los User con rol AGENT son representantes que venden productos de esas Brand
// a EndCustomer (clientes finales), generando Sale y Commission.
// ============================================

enum ProductType {
  LICENSE              // Licencia de software (antivirus, EDR, etc.)
  SAAS_SUBSCRIPTION    // Suscripción SaaS mensual/anual
  AUDIT                // Auditoría puntual de seguridad
  TRAINING             // Formación / curso
  HARDWARE             // Equipo físico
  MANAGED_SERVICE      // Servicio gestionado (SOC, MSSP)
  SUPPORT              // Contrato de soporte
  CONSULTANCY          // Consultoría por horas/proyecto
  CUSTOM               // Genérico
}

enum BillingFrequency {
  ONE_TIME
  MONTHLY
  QUARTERLY
  YEARLY
}

enum CommissionType {
  PERCENTAGE
  FIXED_AMOUNT
  TIERED
}

enum CommissionRuleScope {
  AGENCY
  BRAND
  PRODUCT
  REP
}

enum SaleStatus {
  DRAFT
  PENDING_SIGN
  SIGNED
  ACTIVE
  CANCELLED
  REFUNDED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum AttachmentType {
  ID_DOCUMENT
  PREVIOUS_BILL
  CONTRACT
  PHOTO
  OTHER
}

enum CustomFieldEntity {
  BRAND
  PRODUCT
  CUSTOMER
  SALE
}

enum CustomFieldType {
  STRING
  TEXT
  NUMBER
  DECIMAL
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTISELECT
}

model Brand {
  id            String   @id @default(cuid())
  name          String
  legalName     String?
  taxId         String?
  description   String?  @db.Text
  logo          String?
  website       String?
  contactPerson String?
  contactEmail  String?
  contactPhone  String?
  active        Boolean  @default(true)
  defaultCommissionType  CommissionType @default(PERCENTAGE)
  defaultCommissionValue Decimal        @default(10) @db.Decimal(10, 2)
  customFields  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  products          BrandProduct[]
  sales             Sale[]
  repAssignments    RepBrandAssignment[]
  contractTemplates ContractTemplate[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model BrandProduct {
  id               String           @id @default(cuid())
  sku              String
  name             String
  description      String?          @db.Text
  type             ProductType      @default(CUSTOM)
  billingFrequency BillingFrequency @default(ONE_TIME)
  basePrice        Decimal          @db.Decimal(15, 2)
  cost             Decimal?         @db.Decimal(15, 2)
  taxRate          Decimal          @default(21) @db.Decimal(5, 2)
  currency         String           @default("EUR")
  active           Boolean          @default(true)
  commissionType   CommissionType?
  commissionValue  Decimal?         @db.Decimal(10, 2)
  customFields     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  saleLines SaleLine[]

  @@unique([brandId, sku])
  @@index([organizationId])
  @@index([brandId])
}

model CommissionRule {
  id        String              @id @default(cuid())
  name      String
  scope     CommissionRuleScope
  type      CommissionType
  value     Decimal             @db.Decimal(10, 2)
  config    Json?
  brandId   String?
  productId String?
  repUserId String?
  validFrom DateTime?
  validTo   DateTime?
  active    Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([scope])
}

model RepBrandAssignment {
  id        String   @id @default(cuid())
  territory String?
  customCommissionType  CommissionType?
  customCommissionValue Decimal?        @db.Decimal(10, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([organizationId])
}

model EndCustomer {
  id            String   @id @default(cuid())
  isCompany     Boolean  @default(false)
  firstName     String?
  lastName      String?
  companyName   String?
  taxId         String?
  email         String?
  phone         String?
  mobile        String?
  address       String?
  city          String?
  postalCode    String?
  province      String?
  country       String   @default("España")
  customFields  Json?
  gdprConsent      Boolean   @default(false)
  gdprConsentAt    DateTime?
  marketingConsent Boolean   @default(false)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  sales Sale[]

  @@index([organizationId])
  @@index([taxId])
  @@index([email])
}

model Sale {
  id           String     @id @default(cuid())
  number       String
  status       SaleStatus @default(DRAFT)
  saleDate     DateTime   @default(now())
  signedAt     DateTime?
  activatedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  currency        String  @default("EUR")
  subtotal        Decimal @db.Decimal(15, 2)
  taxAmount       Decimal @db.Decimal(15, 2)
  discount        Decimal @default(0) @db.Decimal(15, 2)
  total           Decimal @db.Decimal(15, 2)
  totalCommission Decimal @default(0) @db.Decimal(15, 2)

  signatureData   String?  @db.Text
  signedPdfUrl    String?
  signatureMethod String?

  notes        String? @db.Text
  customFields Json?

  clientUuid    String?  @unique
  syncedAt      DateTime?
  lastSyncError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brandId String
  brand   Brand  @relation(fields: [brandId], references: [id])

  endCustomerId String
  endCustomer   EndCustomer @relation(fields: [endCustomerId], references: [id])

  representativeId String
  representative   User   @relation("SaleRepresentative", fields: [representativeId], references: [id])

  lines       SaleLine[]
  commissions Commission[]
  attachments Attachment[]

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([status])
  @@index([representativeId])
  @@index([brandId])
}

model SaleLine {
  id          String  @id @default(cuid())
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  total       Decimal @db.Decimal(15, 2)
  commissionType   CommissionType
  commissionValue  Decimal        @db.Decimal(10, 2)
  commissionAmount Decimal        @db.Decimal(15, 2)
  order       Int     @default(0)

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  productId String?
  product   BrandProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
}

model Commission {
  id            String           @id @default(cuid())
  amount        Decimal          @db.Decimal(15, 2)
  currency      String           @default("EUR")
  status        CommissionStatus @default(PENDING)
  paidAt        DateTime?
  paidMethod    String?
  paidReference String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  representativeId String
  representative   User   @relation(fields: [representativeId], references: [id])

  @@index([organizationId])
  @@index([representativeId])
  @@index([status])
}

model Attachment {
  id        String         @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  url       String
  type      AttachmentType @default(OTHER)
  localPath String?
  uploaded  Boolean        @default(true)
  createdAt DateTime       @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  saleId String?
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([saleId])
}

model CustomField {
  id           String            @id @default(cuid())
  entity       CustomFieldEntity
  key          String
  label        String
  type         CustomFieldType
  options      Json?
  required     Boolean           @default(false)
  defaultValue String?
  helpText     String?
  order        Int               @default(0)
  active       Boolean           @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entity, key])
  @@index([organizationId])
}

model ContractTemplate {
  id           String   @id @default(cuid())
  name         String
  version      Int      @default(1)
  htmlContent  String   @db.Text
  pdfHeaderUrl String?
  pdfFooterUrl String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}
