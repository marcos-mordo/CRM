# Variables que Vercel necesita configuradas (Settings > Environment Variables):

# Base de datos (Neon recomendado: https://neon.tech - 0.5GB gratis)
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/brandhub?sslmode=require

# NextAuth
NEXTAUTH_URL=https://tu-app.vercel.app
NEXTAUTH_SECRET=  # generar con: openssl rand -base64 32

# Opcionales (si los activas):
ANTHROPIC_API_KEY=     # AI chat + scoring
STRIPE_SECRET_KEY=     # billing SaaS
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=      # SSO Google
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=    # SSO Microsoft
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
SMTP_HOST=             # email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=    # notificaciones
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=           # protege endpoints /api/cron (Vercel lo añade auto)
