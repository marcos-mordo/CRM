# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:password@localhost:5432/crm_pro?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secret-largo-con-openssl-rand-base64-32"

# SMTP para envío de emails (campañas + notificaciones)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-app-password"
SMTP_FROM="CRM Pro <noreply@tudominio.com>"

# Configuración de la aplicación
APP_NAME="CRM Pro"
DEFAULT_LOCALE="es"
