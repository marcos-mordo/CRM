{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/**/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/generate-recurring-tasks",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 7 * * 1-5"
    },
    {
      "path": "/api/cron/monthly-reports",
      "schedule": "0 9 1 * *"
    },
    {
      "path": "/api/cron/process-sequences",
      "schedule": "0 * * * *"
    }
  ]
}
